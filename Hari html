<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hariram Murukeshan</title>
    <style>
        /* BASE SETTINGS */
        :root {
            --bg: #FAFAFA;       /* Clean Off-White */
            --text: #111111;     /* Near Black for readability */
            --accent: #0070f3;   /* Vercel Blue / Tech Blue */
            --gray: #666666;     /* Subtle Gray */
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--bg);
            color: var(--text);
            line-height: 1.6;
            margin: 0;
            padding: 0;
        }

        /* LAYOUT CONTAINER */
        .container {
            max-width: 650px; /* Optimal reading width like Medium.com */
            margin: 0 auto;
            padding: 40px 20px;
        }

        /* HEADER & NAV */
        header {
            margin-bottom: 60px;
        }

        .profile-img {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            object-fit: cover;
            margin-bottom: 20px;
            border: 3px solid #eaeaea;
        }

        h1 {
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 5px;
            letter-spacing: -0.5px;
        }

        .bio {
            color: var(--gray);
            font-size: 1.1rem;
            margin-bottom: 20px;
        }

        nav a {
            margin-right: 15px;
            text-decoration: none;
            color: var(--text);
            font-size: 0.95rem;
            border-bottom: 1px solid #ddd;
            padding-bottom: 2px;
            transition: all 0.2s ease;
        }
        nav a:hover {
            border-bottom-color: var(--accent);
            color: var(--accent);
        }

        /* SECTIONS */
        .section-header {
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--gray);
            margin-top: 60px;
            margin-bottom: 20px;
            border-bottom: 1px solid #eaeaea;
            padding-bottom: 10px;
        }

        /* POST ITEMS */
        .post-item {
            display: block;
            text-decoration: none;
            margin-bottom: 30px;
            group: hover;
        }

        .post-title {
            font-size: 1.2rem;
            font-weight: 600;
            color: var(--text);
            margin-bottom: 5px;
        }
        
        .post-item:hover .post-title {
            color: var(--accent); /* Blue highlight on hover */
        }

        .post-meta {
            font-size: 0.9rem;
            color: var(--gray);
        }

        /* BUTTONS */
        .btn-linkedin {
            display: inline-block;
            background: #0077b5;
            color: white;
            padding: 10px 20px;
            border-radius: 5px;
            text-decoration: none;
            font-weight: 500;
            margin-top: 20px;
        }
        .btn-linkedin:hover {
            background: #005582;
        }

        /* FOOTER */
        footer {
            margin-top: 80px;
            padding-top: 20px;
            border-top: 1px solid #eaeaea;
            color: var(--gray);
            font-size: 0.85rem;
        }

        /* MOBILE ADJUSTMENTS */
        @media (max-width: 600px) {
            h1 { font-size: 1.8rem; }
            .container { padding: 30px 20px; }
        }
    </style>
</head>
<body>

    <div class="container">
        
        <header>
            <img src="profile.jpg" alt="Hariram Murukeshan" class="profile-img">
            <h1>Hariram Murukeshan</h1>
            <p class="bio">
                Exploring the intersection of <strong>Language</strong>, <strong>Physics</strong>, and <strong>Machine Learning</strong>.
                <br>Sr. Marketing Associate @ Amazon Books.
            </p>
            <nav>
                <a href="#physics">The Lab (Physics)</a>
                <a href="#marketing">Marketing Studio</a>
                <a href="https://www.linkedin.com/in/harirammurukeshan" target="_blank">LinkedIn</a>
            </nav>
        </header>

        <div class="section-header">Recent Research & Learning</div>
        
        <a href="#" class="post-item">
            <div class="post-title">Visualizing Quantum Wave Functions</div>
            <div class="post-meta">Dec 2025 • Python & Physics • 4 min read</div>
        </a>

        <a href="#" class="post-item">
            <div class="post-title">From Newtonian Mechanics to Qubits: My 1-Year Plan</div>
            <div class="post-meta">Nov 2025 • Learning Log • 6 min read</div>
        </a>

        <a href="#" class="post-item">
            <div class="post-title">Notes on Undergraduate Physics: Week 3</div>
            <div class="post-meta">Nov 2025 • Study Notes • 3 min read</div>
        </a>


        <div class="section-header">Marketing & Creative Thoughts</div>

        <a href="#" class="post-item">
            <div class="post-title">Algorithmic Curation in Bookstores</div>
            <div class="post-meta">Oct 2025 • Marketing Strategy • 5 min read</div>
        </a>

        <a href="#" class="post-item">
            <div class="post-title">"The Midnight Archive" (Short Story)</div>
            <div class="post-meta">Sep 2025 • Fiction • 10 min read</div>
        </a>

        <footer>
            © 2025 Hariram Murukeshan.
            <br>
            <span style="font-size: 0.8rem; margin-top: 5px; display:block;">
                Built with HTML/CSS. Hosted on Vercel.
            </span>
        </footer>

    </div>

</body>
</html>